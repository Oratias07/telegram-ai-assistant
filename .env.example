# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# Groq API Key (from console.groq.com)
GROQ_API_KEY=your_groq_key_here

# SQLite database path (optional, default: ./bot.db)
DATABASE_PATH=./bot.db

# Hugging Face token for image generation via FLUX.1-schnell (optional but recommended)
# Get one at https://huggingface.co/settings/tokens — free tier is sufficient
HF_TOKEN=your_hf_token_here
