# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# Groq API Key (from console.groq.com)
GROQ_API_KEY=your_groq_key_here

# SQLite database path (optional, default: ./bot.db)
DATABASE_PATH=./bot.db

# Gemini API key for image generation via Imagen 3 (optional but recommended)
# Get one at https://aistudio.google.com/app/apikey — free tier available
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face token (fallback image provider, optional)
HF_TOKEN=your_hf_token_here
